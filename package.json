{
  "name": "riff",
  "version": "0.1.0",
  "description": "Terminal-based code review companion",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "riff": "./dist/riff"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/riff",
    "build:all": "bun run build:macos-arm64 && bun run build:macos-x64 && bun run build:linux-x64",
    "build:macos-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/riff-darwin-arm64",
    "build:macos-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/riff-darwin-x64",
    "build:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/riff-linux-x64",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.81"
  }
}
